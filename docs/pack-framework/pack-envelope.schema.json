{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jonaminz.com/schemas/declarative-pack-envelope-v1.schema.json",
  "title": "Jonaminz Declarative Pack Envelope v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "packType",
    "packId",
    "name",
    "version",
    "description",
    "targetApp",
    "compatibility",
    "payload"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "packType": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9.-]+@[1-9][0-9]*$"
    },
    "packId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "maxLength": 80
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "author": {
      "type": "string",
      "maxLength": 120
    },
    "targetApp": {
      "type": "string",
      "minLength": 1
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rendererVersion"
      ],
      "properties": {
        "appVersion": {
          "type": "string"
        },
        "rendererVersion": {
          "type": "string"
        }
      }
    },
    "payload": {
      "type": "object"
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object"
      },
      "default": []
    },
    "metadata": {
      "type": "object"
    }
  }
}
